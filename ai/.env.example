# Marka AI - Python Backend (FastAPI) - Environment Variables

# Application
APP_NAME=marka-ai-api
APP_ENV=development
DEBUG=true

# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/marka_ai

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_KEY=queue:agent:

# Pinecone - Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_NAMESPACE=brand-assets

# Google ADK / LLM
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Authentication (required)
JWT_SECRET=your_jwt_secret_key_here
AI_SERVICE_KEY=your_ai_service_key_here

# Scrapling (Web Scraping)
SCRAPING_RATE_LIMIT=5
SCRAPING_TIMEOUT=30

# Optional: OpenAI (if not using ADK)
OPENAI_API_BASE=https://api.openai.com/v1

# ==========================================
# MARKA AI - UNIFIED ENVIRONMENT VARIABLES
# ==========================================

# --- Internal Authentication ---
# X-API-Token for Frontend -> AI Layer
API_TOKEN=your-32-char-random-token-here

# --- LLM Provider (Google Gemini) ---
LLM_API_KEY=your-google-gemini-api-key-here

# --- Smart Orchestrator Model Strategy ---
ORCHESTRATOR_MODEL=google/gemini-3-flash
CONTENT_MODEL=google/gemini-3.1-pro
RAG_MODEL=google/gemini-3.1-flash-lite
CHATBOT_MODEL=google/gemini-3.1-flash-lite
EMBEDDING_MODEL=google/gemini-embedding-2
QDRANT_VECTOR_SIZE=768

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Database & Services (Docker Internal) ---
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=marka_ai
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Rate Limiting ---
LLM_REQUESTS_PER_MINUTE=25
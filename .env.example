# Marka AI - Root Environment Variables Template
#
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
#
# Service-specific .env.example files exist in:
#   - backend/.env.example (Express API Gateway)
#   - frontend/.env.example (React Frontend)
#   - ai/.env.example (FastAPI AI Backend)

# ==========================================
# SHARED - Authentication
# ==========================================
# JWT secret must be identical across all services
JWT_SECRET=your_jwt_secret_key_here

# Service key for Express → FastAPI communication
AI_SERVICE_KEY=your_ai_service_key_here

# ==========================================
# SHARED - Infrastructure
# ==========================================
# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=marka_user
POSTGRES_PASSWORD=marka_password
POSTGRES_DB=marka_db

# Redis Cache/Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# SHARED - External APIs
# ==========================================
# OpenAI API (LLM operations)
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Database (RAG)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_NAMESPACE=brand-assets

# Google Gemini (alternative LLM)
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# FRONTEND (React/Next.js)
# ==========================================
NEXT_PUBLIC_APP_NAME=Marka AI
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ==========================================
# BACKEND (Express)
# ==========================================
APP_NAME=marka-ai-express
APP_ENV=development
PORT=3000
JWT_EXPIRES_IN=7d

# ==========================================
# AI BACKEND (FastAPI)
# ==========================================
# No additional variables beyond shared ones

# ==========================================
# WEB SCRAPING (Scrapling)
# ==========================================
SCRAPING_RATE_LIMIT=5
SCRAPING_TIMEOUT=30

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
# Enable debug logging
DEBUG=false

# Node environment
NODE_ENV=development

# Python unbuffered output
PYTHONUNBUFFERED=1

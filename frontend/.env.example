# Marka AI - React Frontend - Environment Variables

# Application
NEXT_PUBLIC_APP_NAME=Marka AI
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# API Endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Authentication
NEXT_PUBLIC_JWT_SECRET=your_jwt_secret_key_here

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Optional: External Services
NEXT_PUBLIC_GA_ID=your_ga_tracking_id

# Zensical Documentation Preview
NEXT_PUBLIC_DOCS_URL=http://localhost:8000

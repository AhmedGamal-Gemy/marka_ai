# Marka AI - Express Backend - Environment Variables

# Application
APP_NAME=marka-ai-express
APP_ENV=development
PORT=3000

# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/marka_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Optional: External API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Scrapling Rate Limiting
SCRAPING_RATE_LIMIT=5
SCRAPING_TIMEOUT=30
